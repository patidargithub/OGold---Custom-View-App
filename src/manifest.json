{
  "name": "Zendesk Custom Ticket Search",
  "author": {
    "name": "Antigravity",
    "email": "antigravity@example.com"
  },
  "defaultLocale": "en",
  "private": true,
  "location": {
    "support": {
      "nav_bar": {
        "url": "http://localhost:3000/",
        "flexible": true
      }
    }
  },
  "parameters": [
    {
      "name": "columns_config",
      "type": "text",
      "required": false,
      "secure": false,
      "default": "id,subject,status,priority,created_at"
    },
    {
      "name": "page_size",
      "type": "text",
      "required": false,
      "secure": false,
      "default": "25"
    },
    {
      "name": "default_sort_field",
      "type": "text",
      "required": false,
      "secure": false,
      "default": "created_at"
    },
    {
      "name": "default_sort_direction",
      "type": "text",
      "required": false,
      "secure": false,
      "default": "desc"
    },
    {
      "name": "access_roles",
      "type": "text",
      "required": false,
      "secure": false,
      "default": ""
    },
    {
      "name": "access_groups",
      "type": "text",
      "required": false,
      "secure": false,
      "default": ""
    },
    {
      "name": "access_users",
      "type": "text",
      "required": false,
      "secure": false,
      "default": ""
    }
  ],
  "version": "1.0",
  "frameworkVersion": "2.0"
}